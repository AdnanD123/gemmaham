rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // House images (cover, floor plans)
    match /houses/{companyId}/{houseId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Floor plans — company uploads
    match /flats/{companyId}/{flatId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Company logos
    match /companies/{companyId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
    }

    // User profile photos and documents
    match /users/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // Building images (cover, construction photos, contractor logos)
    match /buildings/{companyId}/{buildingId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Contractor profile assets (logo, etc.)
    match /contractors/{contractorId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.uid == contractorId
                   && request.resource.size < 5 * 1024 * 1024;
    }

    // AI-generated renders (written by Cloud Functions via admin SDK)
    match /renders/{flatId}/{allPaths=**} {
      allow read: if true;
    }
  }
}
