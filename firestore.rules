rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function hasRole(role) {
      return isAuthenticated() && (
        request.auth.token.role == role
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role
      );
    }

    function isCompanyMember(companyId) {
      return hasRole('company') && (
        request.auth.token.companyId == companyId
        || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId
      );
    }

    // Users — owner-only read for privacy (agencies read userSnapshot from reservations)
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if false;

      // Favorites subcollection — owner-only
      match /favorites/{propertyId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Notifications subcollection
      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid);
        allow create: if isAuthenticated(); // Cloud Functions + agency assignment notifications
        allow delete: if false;
      }
    }

    // Contractor profiles (top-level collection, registered contractor users)
    match /contractors/{contractorId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == contractorId;
      allow update: if isAuthenticated() && request.auth.uid == contractorId;
      allow delete: if isAuthenticated() && request.auth.uid == contractorId;
    }

    // Collection group rule — required for collectionGroup("contractors") queries
    // (used by getContractorAssignments to find a contractor's building assignments)
    match /{path=**}/contractors/{contractorId} {
      allow read: if true;
    }

    // Companies
    match /companies/{companyId} {
      allow read: if true;
      allow create: if hasRole('company');
      allow update: if isCompanyMember(companyId);
      allow delete: if false;

      // Team members subcollection
      match /members/{memberId} {
        allow read: if isCompanyMember(companyId);
        allow write: if isCompanyMember(companyId);
      }
    }

    // Team invites
    match /invites/{inviteId} {
      allow read: if isAuthenticated() && (
        isCompanyMember(resource.data.companyId)
        || resource.data.email == request.auth.token.email
      );
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data.companyId);
      allow update: if isAuthenticated() && (
        isCompanyMember(resource.data.companyId)
        || resource.data.email == request.auth.token.email
      );
      allow delete: if false;
    }

    // Houses
    match /houses/{houseId} {
      allow read: if true;
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(resource.data.companyId);
      allow delete: if isCompanyMember(resource.data.companyId);
    }

    // Flats
    match /flats/{flatId} {
      allow read: if true;
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(resource.data.companyId);
      allow delete: if isCompanyMember(resource.data.companyId);

      // Customization options subcollection — only owning company can modify
      match /customizations/{optionId} {
        allow read: if true;
        allow create, update, delete: if isCompanyMember(
          get(/databases/$(database)/documents/flats/$(flatId)).data.companyId
        );
      }
    }

    // Buildings
    match /buildings/{buildingId} {
      allow read: if true;
      allow create: if isCompanyMember(request.resource.data.companyId);
      allow update: if isCompanyMember(resource.data.companyId);
      allow delete: if isCompanyMember(resource.data.companyId);

      // Construction updates subcollection — only owning company can modify
      match /updates/{updateId} {
        allow read: if true;
        allow create, update, delete: if isCompanyMember(
          get(/databases/$(database)/documents/buildings/$(buildingId)).data.companyId
        );
      }

      // Contractors subcollection — only owning company can modify
      match /contractors/{contractorId} {
        allow read: if true;
        allow create, update, delete: if isCompanyMember(
          get(/databases/$(database)/documents/buildings/$(buildingId)).data.companyId
        );
      }

      // Milestones subcollection — public read, only owning company can modify
      match /milestones/{milestoneId} {
        allow read: if true;
        allow create, update, delete: if isCompanyMember(
          get(/databases/$(database)/documents/buildings/$(buildingId)).data.companyId
        );
      }

      // Documents subcollection — public read, only owning company can modify
      match /documents/{documentId} {
        allow read: if true;
        allow create, update, delete: if isCompanyMember(
          get(/databases/$(database)/documents/buildings/$(buildingId)).data.companyId
        );
      }
    }

    // Customization Requests
    match /customizationRequests/{requestId} {
      allow read: if isOwner(resource.data.userId)
                  || hasRole('company');
      allow create: if hasRole('user')
                    && request.resource.data.userId == request.auth.uid;
      allow update: if hasRole('company')
                    || (isOwner(resource.data.userId)
                        && request.resource.data.status == 'cancelled');
      allow delete: if false;
    }

    // Contractor Invitations
    match /contractorInvitations/{invitationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.contractorId
        || isCompanyMember(resource.data.companyId)
      );
      allow create: if isAuthenticated() && isCompanyMember(request.resource.data.companyId);
      allow update: if isAuthenticated() && (
        request.auth.uid == resource.data.contractorId
        || isCompanyMember(resource.data.companyId)
      );
      allow delete: if false;
    }

    // Contractor Applications
    match /applications/{applicationId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.contractorUserId
        || isCompanyMember(resource.data.companyId)
      );
      allow create: if hasRole('contractor')
                    && request.resource.data.contractorUserId == request.auth.uid
                    && request.resource.data.status == 'pending';
      allow update: if isCompanyMember(resource.data.companyId)
                    || (request.auth.uid == resource.data.contractorUserId
                        && request.resource.data.status == 'withdrawn');
      allow delete: if false;
    }

    // Reservations
    match /reservations/{reservationId} {
      allow read: if isOwner(resource.data.userId)
                  || isCompanyMember(resource.data.companyId);
      allow create: if hasRole('user')
                    && request.resource.data.userId == request.auth.uid
                    && request.resource.data.status == 'requested';
      allow update: if isCompanyMember(resource.data.companyId)
                    || (isOwner(resource.data.userId)
                        && request.resource.data.status == 'cancelled');
      allow delete: if false;
    }

    // Rate limits — Cloud Functions only (deny all client access)
    match /rateLimits/{docId} {
      allow read, write: if false;
    }

    // Conversations
    match /conversations/{conversationId} {
      allow read: if isOwner(resource.data.userId)
                  || isCompanyMember(resource.data.companyId);
      allow create: if hasRole('user')
                    && request.resource.data.userId == request.auth.uid;
      allow update: if isOwner(resource.data.userId)
                    || isCompanyMember(resource.data.companyId);

      // Messages subcollection
      match /messages/{messageId} {
        allow read: if isAuthenticated()
                    && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid
                        || isCompanyMember(get(/databases/$(database)/documents/conversations/$(conversationId)).data.companyId));
        allow create: if isAuthenticated()
                      && request.resource.data.senderId == request.auth.uid
                      && (get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId == request.auth.uid
                          || isCompanyMember(get(/databases/$(database)/documents/conversations/$(conversationId)).data.companyId));
      }
    }
  }
}
